# ==============================================================================
# ToxiPred .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Data (raw downloads can be re-fetched)
data/raw/*.csv
data/raw/*.gz
data/raw/*.sdf

# Large model files — INCLUDED for cloud deployment
# models/*.joblib
# models/*.pkl
# models/*.json

# Jupyter
.ipynb_checkpoints/
notebooks/*.ipynb

# Logs
*.log

# Artifacts — INCLUDED for cloud deployment
# artifacts/plots/*.png
# artifacts/explanations/*.png
# artifacts/explanations/*.html
# artifacts/metrics/*.json
# artifacts/metrics/*.csv

# Environment files
.env
